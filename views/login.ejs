<!DOCTYPE html>
<html ng-app="beeApp">
<head>
<meta charset="utf-8">
<title>Beeminder Graph Editor</title>
<meta name="description"        content="Make arbitrary changes to your bright red line, subject to the akrasia horizon.">
<meta property="og:description" content="Make arbitrary changes to your bright red line, subject to the akrasia horizon.">
<meta property="og:title" content="Beeminder Graph Editor">
<meta property="og:site_name" content="Beeminder">
<meta property="og:type" content="website">
<link rel="canonical"       href="https://graph.beeminder.com/">
<meta property="og:url"  content="https://graph.beeminder.com/">
<meta property="og:image" content="https://graph.beeminder.com/lib/favicons/beebrain-screenshot.png">
<meta property="og:image:alt" content="Graph editor screenshot">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@bmndr">
<meta name="theme-color" content="#FFCB06">
<link rel="icon" type="image/png" href="/lib/favicons/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/lib/favicons/favicon.svg" />
<link rel="shortcut icon" href="/lib/favicons/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/lib/favicons/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Beeminder Graph Editor" />
<link rel="manifest" href="/lib/favicons/site.webmanifest" />
<script type="application/ld+json"> {
"@context": "https://schema.org",
"@type": "WebSite",
"name": "Beeminder Graph Editor",
"alternateName": ["Beebrain"],
"url": "https://graph.beeminder.com/",
"image": "https://graph.beeminder.com/lib/favicons/beebrain-screenshot.png" }
</script>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  /* This page used to pull in Bootstrap for one centered column and one
     button; that's all self-contained here now (amber to match the app) */
  body { font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont,
                      "Segoe UI", sans-serif; color: #282721; }
  .welcome { max-width: 480px; margin: 0 auto; text-align: center; }
  .loginbtn {
    display: inline-block;
    padding: 12px 22px;
    border: 1px solid #d0a600;
    border-radius: 6px;
    background: #ffcb06;
    color: #282721;
    font-weight: 700;
    text-decoration: none;
  }
  .loginbtn:hover { background: #fff3b0; }
</style>
</head>
<body>

<header>
  <h1 style="text-align: center;">
    Beeminder Graph Editor
  </h1>
  <div style="text-align: center; font-size:1rem; color:#999;">
    [v<%= version %>]
  </div>
</header>

<div style="margin-bottom: 40px;">&nbsp;</div>
<main>
  <!-- Initial welcome screen -->
<div class="welcome"
      ng-if="currentStage == 'initialScreen'">
  <a class="loginbtn" href="<%= AUTHURL %>">
  Log in with your Beeminder account
  </a>
</div>

<div style="margin-bottom: 30px;">&nbsp;</div>

<div style="text-align: center;">
  <a href="/tutorial">Tutorial</a>
</div>

<div style="margin-bottom: 30px;">&nbsp;</div>

<center>
<img
title="Screenshot of the graph editor in action"
  alt="Screenshot of the graph editor in action"
style="max-width: 100%;"
src="/lib/favicons/beebrain-screenshot.png"/>
</center>

</main>

</body>
</html>
