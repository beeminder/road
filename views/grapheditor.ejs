<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <link id="favicon" rel="icon" href="/lib/favicons/bee-with-big-brain.png"
        type="image/png">
  <title>Beeminder Visual Graph Editor</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="../src/pikaday.css">
  <link rel="stylesheet" href="../src/jsbrain.css">
  <link rel="stylesheet" href="../src/tom-select.css">
  <link rel="stylesheet" href="../src/grapheditor.css">
  <script src = "https://d3js.org/d3.v7.js"></script>
  <script src = "../src/moment.js"></script>
  <script src = "../src/moment-timezone.js"></script>
  <script src = "../src/pikaday.js"></script>
  <script src = "../src/polyfit.js"></script>
  <script src = "../src/butil.js"></script>
  <script src = "../src/broad.js"></script>
  <script src = "../src/beebrain.js"></script>
  <script src = "../src/bgraph.js"></script>
  <script src = "../src/bsandbox.js"></script>
  <script src = "../src/tom-select.js"></script>
  <script>
    const username = <%- JSON.stringify(user ? user.username : null) %>;
  </script>
</head>

<body>
  <header id="header">
    <div class="headerinner">
      <a href="https://www.beeminder.com" target="_blank" aria-label="Beeminder">
        <div class="logo"></div>
      </a>
    </div>
  </header>
  <main class="app-shell">
  <div class="goalbar">
    <label for="roadselect">Beeminder goal:</label>
    <select id="roadselect" class="roadselect" onchange="eload=true;gload = true;loadGoals(this.value);">
      <option value="../automon/data/testroad0.bb">Test 0</option>
      <option value="../../privatesuite/data/afcuttin+gmailzero.bb">Test 1</option>
      <option value="../../privatesuite/data/b+coffee2.bb">Test 2</option>
      <option value="../automon/data/testroad2.bb">Test 3</option>
      <option value="../../privatesuite/data/bug-d-bump.bb">Test 4</option>
      <option value="../../privatesuite/data/bug-d-mass.bb">Test 5</option>
      <option value="../automon/data/testroad5.bb">Test 6</option>
      <option value="../../privatesuite/data/bugroad3.bb">Test 7</option>
      <option value="../../privatesuite/data/ybhp-weight-start.bb">Test 8</option>
    </select>
  </div>
  <!-- Tab links -->
  <nav class="tab">
    <button id="graphtab" class="bmdrbtn tablinks active" onclick="openMainTab(event, 'graph');">Graph</button>
    <button id="editortab" class="bmdrbtn tablinks" onclick="openMainTab(event, 'editor')">Graph Editor</button>
    <button id="sandboxtab" class="bmdrbtn tablinks" onclick="openMainTab(event, 'sandbox')">Sandbox</button>
  </nav>
  
<%
/* Per-tab tool rows shared by the graph and editor tabs. p prefixes the
   element ids, obj names the tab's bgraph object in grapheditor.js, and
   extras holds any tab-specific toggles for the zoom row. */
const zoomTools = (p, obj, extras = '') => `
    <div class="graphtools">
      <button class="bmdrbtn" id="${p}zoomall" onclick="${obj}.zoomAll();">View All</button>
      <button class="bmdrbtn" id="${p}zoomdflt" onclick="${obj}.zoomDefault();">Reset Zoom</button>${extras}
    </div>`
const svgTools = (p, obj) => `
    <div class="graphtools">
      <button class="bmdrbtn" id="${p}savesvgblob" onclick="${obj}.saveGraphBlob();">Preview SVG</button>
      <button class="bmdrbtn" id="${p}savesvgdl" onclick="${obj}.saveGraphDownload();">Download SVG</button>
      <span class="checkpair">
        <input id="${p}showcontext" type="checkbox" onclick="${obj}.showContext(this.checked);" checked>
        <label for="${p}showcontext">Include scrubber</label>
      </span>
    </div>`
%>
<!-- Tab content -->
<section id="graph" class="tabcontent" aria-labelledby="graphtab">
  <div id="gsummary" class="summary"></div>
  <div class="workspace">
  <div class="graphcontainer panel">
    <div id="roadgraph"></div>
    <hr/>
    <%- zoomTools('g', 'graph') %>
    <hr/>
    <%- svgTools('g', 'graph') %>

  </div>

  <div class="vtabcontainer panel">
    <div class="vtabtitle">Graph Tools</div>
    <div class="vtab">
      <button class="bmdrbtn gtablinks" onclick="openGraphTab(event, 'road')">Red Line</button><button class="bmdrbtn gtablinks" onclick="openGraphTab(event, 'stats')">Stats</button><button class="bmdrbtn gtablinks" onclick="openGraphTab(event, 'data')">Data</button><button class="bmdrbtn gtablinks active" onclick="openGraphTab(event, 'entry')">Entry</button> <!-- Warning, these elements should be on the same line to prevent inline spacing -->
    </div>
    <div id="entry" class="gtabcontent">
      <div class="tooltitle">Enter new data</div>
      <div class="entryform">
        Date:<br/>
        <input id="datadate" type="text" class="dateentry" placeholder="YYYY-MM-DD"><br/>
        Value:<br/>
        <input id="datavalue" type="number" class="valueentry"><br/>
        Comment:<br/>
        <input id="datacmt" type="text" class="cmtentry"><br/>
        <button class="bmdrbtn" id="dataadd" onclick="handleDataSubmit()">ADD PROGRESS</button>
      </div>
    </div>
    <div id="data" class="gtabcontent">
      <div class="tooltitle">View and edit past data</div>
      <div id="graphdata">
        <input class="data-range" type="range" step="0.5" value="5" min="1" max="10">
      </div>
    </div>
    <div id="stats" class="gtabcontent">
      <div class="tooltitle">Amounts Due By Day</div>
      <div class="duebytable" id="gdueby"></div>
      <div class="tooltitle">Goal Progress</div>
      <div id="gprogress"></div>
    </div>
    <div id="road" class="gtabcontent">
      <div class="tooltitle">Graph Matrix</div>
      <div id="graphroad"></div>
    </div>
  </div>
  </div>
</section>

<section id="editor" class="tabcontent" aria-labelledby="editortab">
  <div id="esummary" class="summary"></div>
  <div class="workspace">
  <div class="graphcontainer panel">
    <details class="hint">
      <summary aria-label="Help">?</summary>
      <div class="hintpop">
        <p>Drag the bright red line or double-click for new segments.</p>
        <p>Knots (shown with vertical lines) are segment boundaries aka kinks in the red line.</p>
        <p>Edit numbers directly in the graph matrix when eyeballing isn't enough.</p>
        <p>Use the scrubber below the graph to zoom and pan.</p>
        <p>You can also pan by dragging the graph itself.</p>
        <p>"Propagate changes forward" is self-explanatory, or will be if you try dragging the red line around with and without it checked.</p>
        <p>("Fixed intervals" is too hard to explain and maybe no one wants or needs it anyway?)</p>
        <p>Nothing takes effect till you hit Submit.</p>
      </div>
    </details>
    <div id="roadeditor"></div>
    <br/>
    <div class="graphtools">
      <button class="bmdrbtn" id="eundo" data-tip="Ctrl-Z / ⌘Z" aria-keyshortcuts="Control+Z Meta+Z" onclick="editor.undo();">Undo (0)</button>
      <button class="bmdrbtn" id="eredo" data-tip="Ctrl-Y / ⇧⌘Z" aria-keyshortcuts="Control+Y Shift+Meta+Z" onclick="editor.redo();">Redo (0)</button>
      <button class="bmdrbtn" id="ereset" onclick="editor.undoAll();">Undo All</button>
      <span class="checkpair">
        <input id="keepslopes" type="checkbox"
               onclick="editor.keepSlopes(this.checked)" checked>
        <label for="keepslopes">Propagate changes forward</label>
      </span>
    </div>
    <hr/>
    <%- zoomTools('e', 'editor', `
      <span class="checkpair">
        <input id="showdata" type="checkbox" onclick="editor.showData(this.checked);" checked>
        <label for="showdata">Show data</label>
      </span>`) %>
    <hr/>
    <%- svgTools('e', 'editor') %>
    <hr/>
    <div class="graphtools">
      <button class="bmdrbtn primary-action" id="submit" onclick="handleRoadSubmit();">Submit</button>
      <span id="submitmsg"></span>
    </div>
    <hr/>
    <details>
      <summary>Experimental features</summary>
      <div class="graphtools">
        <span class="checkpair">
          <input id="keepintervals" type="checkbox"
                 onclick="editor.keepIntervals(this.checked)">
          <label for="keepintervals">Fixed intervals</label>
        </span>
      </div>
    </details>

  </div>
  
  <div class="vtabcontainer panel">
    <div class="vtabtitle">Editor Tools</div>
    <div class="vtab">
      <button class="bmdrbtn etablinks active" onclick="openEditorTab(event, 'eroad')">Red Line</button><button class="bmdrbtn etablinks" onclick="openEditorTab(event, 'estats')">Stats</button><button class="bmdrbtn etablinks" onclick="openEditorTab(event, 'edata')">Data</button><button class="bmdrbtn etablinks" onclick="openEditorTab(event, 'eedit')">Dial</button> <!-- Warning, these elements should be on the same line to prevent inline spacing -->
    </div>
    <div id="eedit" class="etabcontent">
      <div class="tooltitle">Dial Graph</div>
      <div>
        Goal rate:<br/>
        <input type = "number" id="endslope" class="toolinput rateinput" step="any"><br/>
        <select id="slopetype" onchange="updateCommitFields(false)">
          <option value="86400">per day</option>
          <option value="604800">per week</option>
          <option value="2629800">per month</option>
          <option value="31557600">per year</option>
        </select>
        <button class="bmdrbtn" id="commit" onclick="commitTo(false)">UPDATE</button>
      </div>
      <div class="tooltitle">Ratchet</div>
      <div>
        Reduce safety buffer to:<br/>
        <input type="number" value="0" min="0" id="ratchetdays" class="toolinput daysinput"> days
        <button class="bmdrbtn" id="retroratchet" onclick="var val = document.getElementById('ratchetdays').value; if (!isNaN(val)) editor.retroRatchet(Number(val));">Ratchet</button>
      </div>
      <div class="tooltitle">Schedule Break</div>
      <div>
        Start date:<br/>
        <input type="text" id="breakstart" class="toolinput rateinput" placeholder="YYYY-MM-DD"><br/>
        Duration:<br/>
        <input type="number" value="1" min="1" id="breakdays" class="toolinput daysinput"> days<br/>
        <button class="bmdrbtn" id="insertbreak" onclick="scheduleBreak(true);">Insert</button>
        <button class="bmdrbtn" id="overwritebreak" onclick="scheduleBreak(false);">Overwrite</button>
      </div>
    </div>
    <div id="edata" class="etabcontent">
      <div class="tooltitle">View past data</div>
      <div id="editordata">
      </div>
    </div>
    <div id="estats" class="etabcontent">
      <div class="tooltitle">Amounts Due By Day</div>
      <div class="duebytable" id="edueby"></div>
      <div class="tooltitle">Goal Progress</div>
      <div id="eprogress"></div>
    </div>
    <div id="eroad" class="etabcontent">
      <div class="tooltitle">Graph Matrix</div>
      <div id="editorroad"></div>
    </div>
  </div>
  </div>
</section>

<section id="sandbox" class="tabcontent" aria-labelledby="sandboxtab">
  <div id="ssummary" class="summary"></div>
  <div class="workspace">
  <div class="graphcontainer panel">
    <div id="roadsandbox">
    </div>
    <div class="graphtools">
      <button class="bmdrbtn" id="snextday" onclick="sandbox.nextDay();">Next Day</button>
    </div>
    <div class="graphtools">
      <button class="bmdrbtn" id="sundo" data-tip="Ctrl-Z / ⌘Z" aria-keyshortcuts="Control+Z Meta+Z" onclick="sandbox.undo();">Undo (0)</button>
      <button class="bmdrbtn" id="sredo" data-tip="Ctrl-Y / ⇧⌘Z" aria-keyshortcuts="Control+Y Shift+Meta+Z" onclick="sandbox.redo();">Redo (0)</button>
      <button class="bmdrbtn" id="sreset" onclick="sandbox.undoAll();">Undo All</button>
    </div>
    <hr/>
    <div class="graphtools">
      <button class="bmdrbtn" id="szoomall" onclick="sandboxgr.zoomAll();">View All</button>
      <button class="bmdrbtn" id="szoomdflt" onclick="sandboxgr.zoomDefault();">Reset Zoom</button>
    </div>
  </div>
  
  <div class="vtabcontainer panel">
    <div class="vtabtitle">Sandbox Tools</div>
    <div class="vtab">
      <button class="bmdrbtn stablinks" onclick="openSandboxTab(event, 'sroad')">Red Line</button><button class="bmdrbtn stablinks" onclick="openSandboxTab(event, 'sstats')">Stats</button><button class="bmdrbtn stablinks" onclick="openSandboxTab(event, 'sdata')">Data</button><button class="bmdrbtn stablinks active" onclick="openSandboxTab(event, 'sedit')">Edit</button> <!-- Warning, these elements should be on the same line to prevent inline spacing -->
    </div>
    <div id="sedit" class="stabcontent">
      <div class="tooltitle">Dial Graph</div>
      Goal rate:<br/>
      <input type = "number" id="sendslope" class="toolinput rateinput" step="any"><br/>
      <select id="sslopetype" onchange="updateCommitFields(true)">
        <option value="86400">per day</option>
        <option value="604800">per week</option>
        <option value="2629800">per month</option>
        <option value="31557600">per year</option>
      </select> 
      <button class="bmdrbtn" id="scommit" onclick="commitTo(true)">UPDATE</button>
      <div class="tooltitle">Enter new data</div>
      Value:
      <input id="sdataval" class="toolinput daysinput inlinecontrol" type="number">
      Comment:
      <input id="sdatacmt" class="toolinput inlinecontrol" type="text">
      <button class="bmdrbtn inlinecontrol" onclick="sandbox.newData(sdataval.value, sdatacmt.value);">Add</button>
    </div>
    <div id="sdata" class="stabcontent">
      <div class="tooltitle">View past data</div>
      <div id="sandboxdata">
      </div>
    </div>
    <div id="sstats" class="stabcontent">
      <div class="tooltitle">Amounts Due By Day</div>
      <div class="duebytable" id="sdueby"></div>
      <div class="tooltitle">Goal Progress</div>
      <div id="sprogress"></div>
    </div>
    <div id="sroad" class="stabcontent">
      <div class="tooltitle">Graph Matrix</div>
      <div id="sandboxroad"></div>
    </div>
  </div>
  </div>
</section>
</main>

<script src = "../src/grapheditor.js"></script>
<script>
  initialize()
</script>

</body>
</html>
