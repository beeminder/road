<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <link id="favicon" rel="icon" href="/lib/favicons/bee-with-big-brain.png"
        type="image/png">
  <title>Beeminder Sandbox</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="../src/pikaday.css">
  <link rel="stylesheet" href="../src/jsbrain.css">
  <link rel="stylesheet" href="../src/grapheditor.css">
  <script src = "https://d3js.org/d3.v7.js"></script>
  <script src = "../src/moment.js"></script>
  <script src = "../src/moment-timezone.js"></script>
  <script src = "../src/pikaday.js"></script>
  <script src = "../src/polyfit.js"></script>
  <script src = "../src/butil.js"></script>
  <script src = "../src/broad.js"></script>
  <script src = "../src/beebrain.js"></script>
  <script src = "../src/bgraph.js"></script>
  <script src = "../src/bsandbox.js"></script>
</head>

<body>
  <header id="header">
    <div class="headerinner">
      <a class="wordmark" href="https://www.beeminder.com/home" target="_blank">
        <img class="beelogo" src="/lib/favicons/beelogo.png" alt="">
        <span>Beeminder</span>
      </a>
      <span class="apptitle">Sandbox</span>
    </div>
  </header>
  <main class="app-shell">
  <div class="goalbar">
    <label for="typeselect">Select goal type:</label>
    <select id="typeselect" class="typeselect" onchange="setDefaults()">
      <option value="hustler">Do More</option>
      <option value="fatloser">Lose Weight</option>
      <option value="biker">Use an Odometer</option>
      <option value="drinker">Do Less</option>
      <option value="gainer">Gain Weight</option>
      <option value="inboxer">Whittle Down</option>
    </select>
    <span class="checkpair">at a rate of
    <input type="number" value="1" id="rate" class="toolinput daysinput">
    per
    <select id="rateunit" class="typeselect">
      <option value="d">day</option>
      <option value="w">week</option>
      <option value="m">month</option>
      <option value="y">year</option>
    </select>
    </span>
    <span class="checkpair">starting today at
    <input type="number" value="0" id="value" class="toolinput daysinput">
    </span>
    <span class="checkpair">
      <input type="checkbox" id="buffer" checked>
      <label for="buffer">Start one week from today</label>
    </span>
    <button class="bmdrbtn primary-action" id="newgoal" onclick="newGoal();">Create New Goal!</button>
  </div>

<section id="sandbox">
  <div id="ssummary" class="summary"></div>
  <div class="workspace">
  <div class="graphcontainer panel">
    <div class="graphbox">
    <details class="gchip zoom">
      <summary aria-label="Zoom">🔍</summary>
      <div class="chippop">
        <button class="bmdrbtn" id="szoomall" onclick="sandboxgr.zoomAll();">View All</button>
        <button class="bmdrbtn" id="szoomdflt" onclick="sandboxgr.zoomDefault();">Reset Zoom</button>
      </div>
    </details>
      <div id="roadsandbox">
      </div>
    </div>
    <div class="graphtools">
      <button class="bmdrbtn iconbtn" id="sundo" aria-label="Undo" data-tip="Ctrl-Z / ⌘Z" aria-keyshortcuts="Control+Z Meta+Z" onclick="sandbox.undo();"><svg class="uicon" viewBox="0 -960 960 960" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M280-200v-80h284q63 0 109.5-40T720-420q0-60-46.5-100T564-560H312l104 104-56 56-200-200 200-200 56 56-104 104h252q97 0 166.5 63T800-420q0 94-69.5 157T564-200H280Z"/></svg><span id="sundocnt" class="ucnt">0</span></button>
      <button class="bmdrbtn iconbtn" id="sredo" aria-label="Redo" data-tip="Ctrl-Y / ⇧⌘Z" aria-keyshortcuts="Control+Y Shift+Meta+Z" onclick="sandbox.redo();"><svg class="uicon" viewBox="0 -960 960 960" width="15" height="15" fill="currentColor" aria-hidden="true"><g transform="translate(960 0) scale(-1 1)"><path d="M280-200v-80h284q63 0 109.5-40T720-420q0-60-46.5-100T564-560H312l104 104-56 56-200-200 200-200 56 56-104 104h252q97 0 166.5 63T800-420q0 94-69.5 157T564-200H280Z"/></g></svg><span id="sredocnt" class="ucnt">0</span></button>
      <button class="bmdrbtn" id="snextday" onclick="sandbox.nextDay();">Next Day</button>
    </div>
  </div>

  <div class="vtabcontainer panel">
    <div class="vtabtitle">Sandbox Tools</div>
    <div class="vtab">
      <button class="bmdrbtn stablinks" onclick="openSandboxTab(event, 'sroad')">Red Line</button><button class="bmdrbtn stablinks" onclick="openSandboxTab(event, 'sstats')">Stats</button><button class="bmdrbtn stablinks" onclick="openSandboxTab(event, 'sdata')">Data</button><button class="bmdrbtn stablinks active" onclick="openSandboxTab(event, 'sedit')">Edit</button> <!-- Warning, these elements should be on the same line to prevent inline spacing -->
    </div>
    <div id="sedit" class="stabcontent">
      <div class="tooltitle">Dial Graph</div>
      Goal rate:<br/>
      <input type = "number" id="sendslope" class="toolinput rateinput" step="any"><br/>
      <select id="sslopetype" onchange="updateCommitFields()">
        <option value="86400">per day</option>
        <option value="604800">per week</option>
        <option value="2629800">per month</option>
        <option value="31557600">per year</option>
      </select>
      <button class="bmdrbtn" id="scommit" onclick="commitTo()">UPDATE</button>
      <div class="tooltitle">Enter new data</div>
      Value:
      <input id="sdataval" class="toolinput daysinput inlinecontrol" type="number">
      Comment:
      <input id="sdatacmt" class="toolinput inlinecontrol" type="text">
      <button class="bmdrbtn inlinecontrol" onclick="sandbox.newData(sdataval.value, sdatacmt.value);">Add</button>
    </div>
    <div id="sdata" class="stabcontent">
      <div class="tooltitle">View past data</div>
      <div id="sandboxdata">
      </div>
    </div>
    <div id="sstats" class="stabcontent">
      <div class="tooltitle">Amounts Due By Day</div>
      <div class="duebytable" id="sdueby"></div>
      <div class="tooltitle">Goal Progress</div>
      <div id="sprogress"></div>
    </div>
    <div id="sroad" class="stabcontent">
      <div class="tooltitle">Graph Matrix</div>
      <div id="sandboxroad"></div>
    </div>
  </div>
  </div>
</section>
</main>

<footer class="pagefoot">
  <a class="primefoot" href="https://www.beeminder.com" target="_blank">Beeminder proper</a>
  <nav class="footlinks">
    <a href="/">Beeminder Visual Graph Editor</a>
    <a href="/tutorial">Tutorial</a>
  </nav>
  <span class="versiontag">v<%= version %></span>
</footer>

<script src = "../src/pagekit.js"></script>
<script src = "../src/sandboxpage.js"></script>
<script>
  initialize()
</script>

</body>
</html>
